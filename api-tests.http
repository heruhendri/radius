###
# SALFANET RADIUS - API Testing with REST Client
# VS Code Extension: REST Client by Huachao Mao
# 
# Usage: Click "Send Request" above each request
###

@baseUrl = http://localhost:3000
@authToken = 

### ========================================
### HEALTH & SYSTEM
### ========================================

### Health Check
GET {{baseUrl}}/api/health

### Company Info (Public)
GET {{baseUrl}}/api/company

### Company Settings (Public)
GET {{baseUrl}}/api/settings/company

### ========================================
### AUTHENTICATION
### ========================================

### Admin Login
# @name adminLogin
POST {{baseUrl}}/api/auth/signin
Content-Type: application/json

{
  "email": "admin@test.com",
  "password": "password"
}

### Customer Send OTP
POST {{baseUrl}}/api/customer/auth/send-otp
Content-Type: application/json

{
  "phone": "08123456789"
}

### Customer Verify OTP
POST {{baseUrl}}/api/customer/auth/verify-otp
Content-Type: application/json

{
  "phone": "08123456789",
  "otp": "123456"
}

### Technician Send OTP
POST {{baseUrl}}/api/technician/auth/send-otp
Content-Type: application/json

{
  "phone": "08123456789"
}

### ========================================
### PPPOE USERS (Requires Auth)
### ========================================

### Get PPPoE Users List
GET {{baseUrl}}/api/pppoe
Authorization: Bearer {{authToken}}

### Get Single PPPoE User
GET {{baseUrl}}/api/pppoe/1
Authorization: Bearer {{authToken}}

### Create PPPoE User
POST {{baseUrl}}/api/pppoe
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "username": "testuser",
  "password": "testpass",
  "profileId": "1",
  "customerId": "CUST001"
}

### Update PPPoE User
PUT {{baseUrl}}/api/pppoe/1
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "password": "newpassword"
}

### Delete PPPoE User
DELETE {{baseUrl}}/api/pppoe/1
Authorization: Bearer {{authToken}}

### ========================================
### HOTSPOT VOUCHERS (Requires Auth)
### ========================================

### Get Hotspot Vouchers
GET {{baseUrl}}/api/hotspot
Authorization: Bearer {{authToken}}

### Generate Vouchers
POST {{baseUrl}}/api/hotspot/generate
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "profileId": "1",
  "quantity": 10,
  "prefix": "TEST"
}

### ========================================
### INVOICES
### ========================================

### Get All Invoices
GET {{baseUrl}}/api/invoices
Authorization: Bearer {{authToken}}

### Get Customer Invoices
GET {{baseUrl}}/api/customer/invoices
Authorization: Bearer {{authToken}}

### Generate Invoice
POST {{baseUrl}}/api/invoices/generate
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "userId": "1",
  "amount": 100000
}

### ========================================
### MANUAL PAYMENTS
### ========================================

### Get Manual Payments
GET {{baseUrl}}/api/manual-payments
Authorization: Bearer {{authToken}}

### Submit Manual Payment
POST {{baseUrl}}/api/manual-payments
Content-Type: application/json

{
  "invoiceId": "1",
  "bankName": "BCA",
  "accountName": "John Doe",
  "transferDate": "2026-01-18",
  "amount": 100000,
  "proofImageUrl": "/uploads/proof.jpg"
}

### Approve Manual Payment
PUT {{baseUrl}}/api/manual-payments/1/approve
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "status": "APPROVED"
}

### ========================================
### PAYMENT GATEWAYS
### ========================================

### Get Payment Gateways
GET {{baseUrl}}/api/payment-gateways

### Midtrans Payment Notification (Webhook)
POST {{baseUrl}}/api/webhooks/midtrans
Content-Type: application/json

{
  "order_id": "INV-001",
  "transaction_status": "settlement"
}

### ========================================
### WHATSAPP INTEGRATION
### ========================================

### Get WhatsApp Providers
GET {{baseUrl}}/api/whatsapp/providers
Authorization: Bearer {{authToken}}

### Get WhatsApp Templates
GET {{baseUrl}}/api/whatsapp/templates
Authorization: Bearer {{authToken}}

### Send WhatsApp Message
POST {{baseUrl}}/api/whatsapp/send
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "phone": "08123456789",
  "message": "Test message"
}

### WhatsApp Broadcast
POST {{baseUrl}}/api/whatsapp/broadcast
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "message": "Broadcast message",
  "targetType": "ALL"
}

### ========================================
### NAS (NETWORK ACCESS SERVER)
### ========================================

### Get NAS List
GET {{baseUrl}}/api/nas
Authorization: Bearer {{authToken}}

### Add NAS
POST {{baseUrl}}/api/nas
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "nasname": "192.168.1.1",
  "shortname": "MikroTik-1",
  "secret": "radius-secret",
  "type": "mikrotik"
}

### ========================================
### TICKETS / SUPPORT
### ========================================

### Get Tickets
GET {{baseUrl}}/api/tickets
Authorization: Bearer {{authToken}}

### Get Ticket Stats
GET {{baseUrl}}/api/tickets/stats
Authorization: Bearer {{authToken}}

### Create Ticket
POST {{baseUrl}}/api/tickets
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "subject": "Internet Issue",
  "description": "Connection keeps dropping",
  "priority": "HIGH"
}

### ========================================
### TECHNICIAN
### ========================================

### Get Work Orders
GET {{baseUrl}}/api/technician/work-orders
Authorization: Bearer {{authToken}}

### Update Work Order
POST {{baseUrl}}/api/technician/work-orders
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "workOrderId": "1",
  "action": "complete"
}

### ========================================
### SYSTEM & ADMIN
### ========================================

### Get RADIUS Status
GET {{baseUrl}}/api/system/radius
Authorization: Bearer {{authToken}}

### Database Backup
POST {{baseUrl}}/api/backup
Authorization: Bearer {{authToken}}

### Get Dashboard Stats
GET {{baseUrl}}/api/dashboard/stats
Authorization: Bearer {{authToken}}

### ========================================
### FILE UPLOAD
### ========================================

### Upload Logo
POST {{baseUrl}}/api/upload/logo
Authorization: Bearer {{authToken}}
Content-Type: multipart/form-data; boundary=----WebKitFormBoundary

------WebKitFormBoundary
Content-Disposition: form-data; name="file"; filename="logo.png"
Content-Type: image/png

< ./path/to/logo.png
------WebKitFormBoundary--

### Upload Payment Proof
POST {{baseUrl}}/api/upload/payment-proof
Content-Type: multipart/form-data; boundary=----WebKitFormBoundary

------WebKitFormBoundary
Content-Disposition: form-data; name="file"; filename="proof.jpg"
Content-Type: image/jpeg

< ./path/to/proof.jpg
------WebKitFormBoundary--

### ========================================
### ERROR TESTING
### ========================================

### Non-existent Endpoint (404)
GET {{baseUrl}}/api/nonexistent

### Unauthorized Access (401)
GET {{baseUrl}}/api/pppoe

### Invalid Data (400)
POST {{baseUrl}}/api/customer/auth/send-otp
Content-Type: application/json

{
  "phone": ""
}
