# Database - MySQL with proper timezone handling
DATABASE_URL="mysql://username:password@localhost:3306/database_name?connection_limit=10&pool_timeout=20"

# Timezone - CRITICAL for WIB handling
TZ="Asia/Jakarta"
NEXT_PUBLIC_TIMEZONE="Asia/Jakarta"

# App Configuration
NEXT_PUBLIC_APP_NAME="Your ISP Name"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# RADIUS Server Configuration
# IP yang ditampilkan di script setup MikroTik
# Jika tidak diset, sistem akan auto-detect dari network interface server
# RADIUS_SERVER_IP="YOUR_VPS_PUBLIC_IP"
# VPS_IP="YOUR_VPS_PUBLIC_IP"

# NextAuth
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Agent Portal JWT
# Generate with: openssl rand -base64 32
AGENT_JWT_SECRET=your-agent-jwt-secret-here-generate-with-openssl-rand-base64-32

# Encryption Key for sensitive data at rest (GenieACS password, VPN credentials)
# REQUIRED in production! Generate with: openssl rand -hex 16
ENCRYPTION_KEY=your-32-char-hex-key-generate-with-openssl-rand-hex-16

# ──────────────────────────────────────────────────────────────
# GenieACS — TR-069 ACS integration
# ──────────────────────────────────────────────────────────────
# URL NBI diakses DARI server Next.js (server-side only)
# Gunakan IP internal jika GenieACS & Next.js satu host, misalnya:
#   http://127.0.0.1:7557
GENIEACS_NBI_INTERNAL_URL="http://127.0.0.1:7557"

# URL NBI yang dipublikasi (untuk referensi saja, tidak dipakai client-side)
NEXT_PUBLIC_GENIEACS_NBI_URL="http://YOUR_VPS_IP:7557"

# CWMP listener (port yang CPE/modem tuju)
NEXT_PUBLIC_GENIEACS_CWMP_URL="http://YOUR_VPS_IP:7547"

# GenieACS File Server
NEXT_PUBLIC_GENIEACS_FS_URL="http://YOUR_VPS_IP:7567"

# MongoDB GenieACS (jika mengaktifkan mongodb-client langsung)
# Format: mongodb://user:pass@host:27017/genieacs
GENIEACS_MONGODB_URL="mongodb://127.0.0.1:27017/genieacs"

# Kredensial NBI (opsional jika GenieACS tidak diset auth)
GENIEACS_NBI_USERNAME=""
GENIEACS_NBI_PASSWORD=""

# Timeout sesi task GenieACS (detik)
GENIEACS_SESSION_TIMEOUT="3600"

# Channel default untuk preset
GENIEACS_DEFAULT_CHANNEL="default"

# Interval polling data perangkat di UI (ms)
NEXT_PUBLIC_GENIEACS_POLL_INTERVAL="30000"

# ──────────────────────────────────────────────────────────────
# Web Push (PWA)
# Generate with: npm run push:vapid
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_CONTACT_EMAIL="admin@example.com"

